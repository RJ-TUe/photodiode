"""
Photodetector Physics Model
===========================
Implements the carrier rate equation (4.1) and Gauss's law (4.2) for a
semiconductor photodetector under illumination and applied bias.

Rate equation (4.1):
    ∂n/∂t = G - R - (1/q) ∇·(J_drift(E) + J_diff(E))

Gauss's law (4.2):
    ∇·E = (q/ε)(p - n + N_n - N_p)

The model is 0-D (lumped / uniform-field), so spatial derivatives are
replaced by effective quantities: the divergence of J becomes J_total/d,
where d is the absorption layer thickness.

Inputs
------
  - Wavelength λ [m]
  - Photon flux Φ [photons m⁻² s⁻¹]
  - Bias voltage V_bias [V]
  - Semiconductor material (choose from MATERIALS dict)

Outputs
-------
  - Steady-state electron density n [m⁻³]
  - Electric field E [V/m]
  - Photocurrent density J [A/m²]
  - Responsivity R [A/W]
  - Quantum efficiency η_int (internal, after absorption)
"""

import numpy as np
from scipy.integrate import solve_ivp
from scipy.optimize import brentq
import warnings

# ── Physical constants ────────────────────────────────────────────────────────
q   = 1.602e-19   # Elementary charge [C]
eps0= 8.854e-12   # Permittivity of free space [F/m]
hc  = 1.986e-25   # h·c  [J·m]
kB  = 1.381e-23   # Boltzmann constant [J/K]

# ── Semiconductor material library ───────────────────────────────────────────
# All parameters at 300 K unless noted.
# Sources: Sze & Ng "Physics of Semiconductor Devices", 3rd ed.
MATERIALS = {
    "Si": {
        "description"    : "Silicon — workhorse detector, NIR",
        "bandgap_eV"     : 1.12,          # E_g [eV]
        "epsilon_r"      : 11.7,          # Relative permittivity
        "mu_n"           : 0.1350,        # Electron mobility [m²/V·s]
        "mu_p"           : 0.0480,        # Hole mobility [m²/V·s]
        "tau_n"          : 1e-6,          # Electron lifetime [s]  (lightly doped)
        "tau_p"          : 1e-6,          # Hole lifetime [s]
        "n_i"            : 9.65e9 * 1e6,  # Intrinsic carrier density [m⁻³]
        "alpha_coeff"    : (1e7, 1.1e-6), # (α₀ [m⁻¹], λ_gap [m]) for Urbach model
        "D_n"            : 0.0025,        # Electron diffusivity [m²/s]  (D=μkT/q)
        "D_p"            : 0.00125,
    },
    "GaAs": {
