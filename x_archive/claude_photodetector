# ── Wavelength sweep utility ──────────────────────────────────────────────────

def sweep_wavelength(
    wavelengths_nm: list,
    flux: float,
    material_name: str = "Si",
    V_bias: float = -5.0,
    **kwargs,
) -> list:
    """
    Run solve_photodetector across a list of wavelengths [nm].
    Returns a list of result dicts.
    """
    results = []
    for lam_nm in wavelengths_nm:
        try:
            r = solve_photodetector(
                wavelength=lam_nm * 1e-9,
                flux=flux,
                material_name=material_name,
                V_bias=V_bias,
                **kwargs,
            )
            results.append(r)
        except Exception as e:
            warnings.warn(f"λ={lam_nm} nm failed: {e}")
    return results


