    sep = "─" * 60
    mat = MATERIALS[res["material"]]
    print(f"\n{'═'*60}")
    print(f"  Photodetector Model Results")
    print(f"  Material : {res['material']}  — {mat['description']}")
    print(f"{'═'*60}")

    print(f"\n{'OPTICAL':─<40}")
    print(f"  Wavelength         : {res['wavelength_nm']:.1f} nm")
